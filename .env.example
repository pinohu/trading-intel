TRADING_ACCESS_CODE=change-me
TRADING_ACCESS_TOKEN=change-this-to-a-long-random-token

# Optional real-data provider keys.
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
BENZINGA_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=
SEC_USER_AGENT=trading-intel-platform contact@example.com

# Optional cross-database companion. DATABASE_URL remains the primary SQL target.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# External research workers. Use these for heavy engines that should not run in
# Vercel serverless functions.
OPENBB_WORKER_URL=
LEAN_WORKER_URL=
BACKTRADER_WORKER_URL=
VECTORBT_WORKER_URL=
NAUTILUS_WORKER_URL=
FINGPT_WORKER_URL=
FINRL_WORKER_URL=
JESSE_WORKER_URL=
WORKER_SHARED_SECRET=
WORKER_TIMEOUT_MS=25000

# Optional AITable operations mirror/fallback. This is useful for human-readable
# signal, paper trade, ticket, and broker order records when SQL storage is down.
AITABLE_MIRROR_ENABLED=false
AITABLE_API_KEY=
AITABLE_BASE_URL=https://aitable.ai
AITABLE_SPACE_ID=
AITABLE_QUOTE_SNAPSHOTS_DATASHEET_ID=
AITABLE_SIGNAL_SNAPSHOTS_DATASHEET_ID=
AITABLE_TRADE_TICKETS_DATASHEET_ID=
AITABLE_PAPER_TRADES_DATASHEET_ID=
AITABLE_BROKER_ORDERS_DATASHEET_ID=
AITABLE_SIGNAL_OUTCOMES_DATASHEET_ID=
AITABLE_WATCHLIST_DATASHEET_ID=

# Always-on monitor and alerts.
CRON_SECRET=change-this-to-a-long-random-token
MONITOR_WATCHLIST=SPY,QQQ,NVDA,TSLA,AAPL,MSFT,AMD,COIN,GLD,SLV,USO,UNG,GOLD,SILVER,OIL,NATGAS,COPPER,CORN,WHEAT,SOY,BTCUSD,ETHUSD
DEFAULT_RISK_PCT=1
DEFAULT_ACCOUNT_SIZE=10000
DEFAULT_MAX_DAILY_LOSS_PCT=3
PROVIDER_TIMEOUT_MS=3500
# Production should keep this false. When true, failed providers can return deterministic demo quotes.
DEMO_MARKET_DATA=false
SEND_MONITOR_ALERTS=false
ALERT_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_TO_PHONE=
RESEND_API_KEY=
ALERT_TO_EMAIL=
ALERT_FROM_EMAIL=

# Institutional worker path. Vercel cron remains the baseline; these flags track
# whether you have also launched persistent external workers.
TRADING_APP_URL=https://trading-intel-platform.vercel.app
ENABLE_MARKET_WORKER=false
ENABLE_ALPACA_TRADE_UPDATE_WORKER=false
MARKET_WORKER_INTERVAL_MS=30000
PROOF_WORKER_INTERVAL_MS=60000
TRADING_SESSION_COOKIE=
AUTORESEARCH_SYMBOLS=SPY,QQQ,NVDA,TSLA,AAPL,MSFT
AUTORESEARCH_BUDGET=3
AUTORESEARCH_LOOKBACK_DAYS=180
AUTORESEARCH_INTERVAL_MS=86400000
AUTORESEARCH_LOOP=false

# AI agent trading. Live-money autonomy is blocked in code. These flags only
# allow supervised proposal generation and optional Alpaca paper-order submission.
AGENT_TRADING_ENABLED=false
AGENT_PAPER_TRADING_ENABLED=false
AGENT_MIN_CONFIDENCE=75
AGENT_MAX_PROPOSALS=5
AGENT_MAX_PAPER_ORDERS_PER_RUN=1
AGENT_PAPER_WORKER_INTERVAL_MS=60000
AGENT_PAPER_WORKER_LOOP=true
AGENT_PAPER_ACCOUNT_SIZE=10000
AGENT_PAPER_RISK_PCT=1
AGENT_PAPER_MAX_DAILY_LOSS_PCT=3
AGENT_PAPER_SYMBOLS=SPY,QQQ,NVDA,TSLA,AAPL,MSFT,AMD,COIN,GLD,SLV,USO,UNG

# Compliance boundary. Keep personalized/paid advice flags false unless reviewed
# by qualified securities counsel.
ENABLE_PERSONALIZED_ADVICE=false
ENABLE_PAID_USERS=false
COMPLIANCE_OFFICER_EMAIL=

# Broker order placement. Keep disabled until you have tested paper trading and applied database/schema.sql.
BROKER_EXECUTION_ENABLED=false
# paper or live. Live uses https://api.alpaca.markets; paper uses https://paper-api.alpaca.markets.
BROKER_EXECUTION_MODE=paper
BROKER_MAX_ORDER_NOTIONAL=5000
BROKER_MAX_ORDER_UNITS=100
BROKER_ALLOW_EXTENDED_HOURS=false
TRADING_KILL_SWITCH=false
CONTROL_ALLOW_LIVE_ORDERS=true
# Live mode hard gates. The app allows manual live orders by default when live keys are present.
# Set ALPACA_LIVE_TRADING_ENABLED=false only when you intentionally want to force-disable live mode.
ALPACA_LIVE_TRADING_ENABLED=
BROKER_LIVE_EXECUTION_ACK=

# Optional no/low-cost market data accounts.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_API_KEY_ID=
ALPACA_PAPER_API_SECRET_KEY=
ALPACA_PAPER_API_ENDPOINT_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_API_KEY_ID=
ALPACA_LIVE_API_SECRET_KEY=
ALPACA_LIVE_API_ENDPOINT_URL=https://api.alpaca.markets
# Set to sip only if your Alpaca account has SIP data permissions.
ALPACA_DATA_QUALITY=iex
